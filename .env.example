# FlashOfThought 环境配置模板
# 复制此文件为 .env 并填入实际值

# 阿里云OSS配置
OSS_ENDPOINT=https://your-bucket-name.oss-cn-beijing.aliyuncs.com
OSS_BUCKET_AUDIO=your-bucket-name
OSS_ACCESS_KEY_ID=your_access_key_id_here
OSS_ACCESS_KEY_SECRET=your_access_key_secret_here
OSS_PUBLIC_BASE_URL=https://your-bucket-name.oss-cn-beijing.aliyuncs.com
OSS_USE_SIGNED_URL=true
OSS_SIGNED_URL_EXPIRE_SEC=3600

# 阿里云DashScope配置
DASHSCOPE_API_KEY=your_dashscope_api_key_here
QWEN_CHAT_MODEL=qwen-plus
QWEN_EMBED_MODEL=text-embedding-v4
QWEN_ASR_MODEL=qwen3-asr-flash

# 向量数据库路径
CHROMA_DB_PATH=./data/chroma_db

# API配置
API_BASE_URL=http://localhost:8000/api/v1

# Admin
# Comma-separated emails that can access /api/v1/admin and the Admin UI page.
ADMIN_EMAILS=admin@example.com
