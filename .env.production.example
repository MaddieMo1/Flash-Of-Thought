# Production template. Copy to .env on the server and fill real secrets.

# Streamlit calls the FastAPI service from inside Docker.
API_BASE_URL=http://api:8000/api/v1

# Persistent data paths inside the containers.
USERS_DB_PATH=/app/data/users.sqlite3
CHROMA_DB_PATH=/app/data/chroma_db

# Auth. Replace with a long random value before deploying.
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Alibaba Cloud OSS
STORAGE_PROVIDER=oss
OSS_ENDPOINT=https://your-bucket-name.oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_AUDIO=your-bucket-name
OSS_ACCESS_KEY_ID=your_access_key_id_here
OSS_ACCESS_KEY_SECRET=your_access_key_secret_here
OSS_PUBLIC_BASE_URL=https://your-bucket-name.oss-cn-hangzhou.aliyuncs.com
OSS_USE_SIGNED_URL=true
OSS_SIGNED_URL_EXPIRE_SEC=3600

# DashScope / Qwen
DASHSCOPE_API_KEY=your_dashscope_api_key_here
QWEN_CHAT_MODEL=qwen-plus
QWEN_EMBED_MODEL=text-embedding-v4
QWEN_ASR_MODEL=qwen3-asr-flash
